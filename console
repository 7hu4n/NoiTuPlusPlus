        .multiple-mode-lobby_rankedBtn__EG4j8 svg,
        .columns.is-multiline a.column .button svg {
            color: #ff0000 !important;
            stroke: #ff0000 !important;
            filter: drop-shadow(0 0 5px rgba(255, 0, 0, 0.8)) !important;
        }
        .tag.is-dark {
            background-color: rgba(255, 0, 0, 0.2) !important;
            border: 1px solid #ff0000 !important;
            color: #ff0000 !important;
        }
        .field.has-addons .input,
        .field.has-addons .button {
            border: none !important;
            outline: none !important;
            box-shadow: none !important;
            background: linear-gradient(90deg, #000, #ff0000, #000) !important;
            background-size: 200% auto !important;
            animation: head-gradient 3s linear infinite !important;
            color: white !important;
        }
        .input:focus, .input:active, .button:focus, .button:active {
            outline: none !important;
            border: none !important;
            box-shadow: 0 0 12px rgba(255, 0, 0, 0.4) !important;
        }
        progress.progress::-webkit-progress-value {
            background: linear-gradient(90deg, #000, #ff0000, #000) !important;
            background-size: 200% auto !important;
            animation: head-gradient 3s linear infinite !important;
        }

        .glass-btn {
            backdrop-filter: blur(10px) !important;
            background: rgba(255, 255, 255, 0.05) !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            color: white !important;
            font-family: monospace !important;
            text-shadow: 0 0 5px rgba(255,255,255,0.3);
            padding: 12px 20px;
            border-radius: 10px;
            font-weight: bold;
            cursor: pointer;
            font-size: 13px;
            min-width: 190px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
        }
        .glass-btn:hover {
            transform: scale(1.05) translateY(-2px) !important;
        }
        .nut-nap { border-color: #00d2ff !important; color: #00d2ff !important; }
        .nut-nap:hover { box-shadow: 0 0 15px #00d2ff !important; }
        .nut-tim { border-color: #9d50bb !important; color: #9d50bb !important; }
        .nut-tim:hover { box-shadow: 0 0 15px #9d50bb !important; }
        .nut-an-toan { border-color: #00ff87 !important; color: #00ff87 !important; }
        .nut-an-toan:hover { box-shadow: 0 0 15px #00ff87 !important; }
        .nut-turbo { border-color: #ff0000 !important; color: #ff0000 !important; }
        .nut-turbo:hover { box-shadow: 0 0 15px #ff0000 !important; }
        .nut-dang-dung {
            background: rgba(255, 0, 0, 0.2) !important;
            animation: rung 0.4s infinite !important;
        }
        @keyframes rung {
            0% { transform: translate(1px, 1px); }
            50% { transform: translate(-1px, -1px); }
            100% { transform: translate(1px, 1px); }
